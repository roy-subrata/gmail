@page "/mail"
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>@(_openEmail != null ? _openEmail.Subject + " – Gmail" : _activeFolder + " – Gmail")</PageTitle>

<div class="gmail-shell">

    <!-- ===== TOP BAR ===== -->
    <header class="gmail-topbar">
        <div class="gmail-topbar-left">
            <button class="gmail-icon-btn gmail-menu-btn" aria-label="Main menu" @onclick="ToggleSidebar">
                <span class="material-icons">menu</span>
            </button>
            <a href="#" class="gmail-logo-link" aria-label="Gmail">
                <GmailLogo />
                <span class="gmail-logo-text">Gmail</span>
            </a>
        </div>

        <div class="gmail-search" role="search">
            <button class="gmail-search-icon-btn" aria-label="Search">
                <span class="material-icons">search</span>
            </button>
            <input type="text" placeholder="Search mail" class="gmail-search-input"
                   aria-label="Search mail" @bind="_searchQuery" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_searchQuery))
            {
                <button class="gmail-search-clear" aria-label="Clear" @onclick="@(() => _searchQuery = "")">
                    <span class="material-icons">close</span>
                </button>
            }
            <button class="gmail-search-filter-btn" aria-label="Search options">
                <span class="material-icons">tune</span>
            </button>
        </div>

        <div class="gmail-topbar-right">
            <button class="gmail-icon-btn" aria-label="Help"><span class="material-icons">help_outline</span></button>
            <button class="gmail-icon-btn" aria-label="Settings"><span class="material-icons">settings</span></button>
            <button class="gmail-icon-btn gmail-apps-btn" aria-label="Google apps">
                <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#5f6368" d="M6 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM6 14c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM6 20c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6 0c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/>
                </svg>
            </button>
            <button class="gmail-avatar" aria-label="Google Account" @onclick="ToggleAccountMenu">
                @_userInitial
            </button>
        </div>
    </header>

    <!-- Account dropdown -->
    @if (_showAccountMenu)
    {
        <div class="acct-overlay" @onclick="() => _showAccountMenu = false"></div>
        <div class="acct-menu" role="menu">
            <div class="acct-menu-top">
                <div class="acct-menu-avatar">@_userInitial</div>
                <div class="acct-menu-info">
                    <div class="acct-menu-name">Gmail User</div>
                    <div class="acct-menu-email">@_userEmail</div>
                </div>
            </div>
            <hr class="acct-divider" />
            <button class="acct-menu-item" role="menuitem" @onclick="@(() => Nav.NavigateTo("/dashboard"))">
                <span class="material-icons">admin_panel_settings</span>
                Login Log Dashboard
            </button>
            <hr class="acct-divider" />
            <button class="acct-menu-item acct-signout" role="menuitem" @onclick="SignOut">
                <span class="material-icons">logout</span>
                Sign out
            </button>
        </div>
    }

    <!-- Mobile sidebar overlay -->
    @if (_sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseSidebar" aria-hidden="true"></div>
    }

    <div class="gmail-body">

        <!-- ===== SIDEBAR ===== -->
        <nav class="gmail-sidebar @(_sidebarOpen ? "sidebar-open" : "")" aria-label="Folders">
            <button class="gmail-compose-btn" aria-label="Compose">
                <span class="material-icons">edit</span>
                <span class="compose-label">Compose</span>
            </button>
            <ul class="gmail-nav-list">
                <li class="gmail-nav-item @(_activeFolder == "Inbox" && _openEmail == null ? "active" : "")"
                    @onclick='() => { NavTo("Inbox"); CloseEmail(); }'>
                    <span class="material-icons">inbox</span>
                    <span class="nav-label">Inbox</span>
                    @if (_inboxUnreadCount > 0) { <span class="nav-badge">@_inboxUnreadCount</span> }
                </li>
                <li class="gmail-nav-item @(_activeFolder == "Starred" && _openEmail == null ? "active" : "")"
                    @onclick='() => { NavTo("Starred"); CloseEmail(); }'>
                    <span class="material-icons">@(_activeFolder == "Starred" ? "star" : "star_border")</span>
                    <span class="nav-label">Starred</span>
                </li>
                <li class="gmail-nav-item @(_activeFolder == "Snoozed" && _openEmail == null ? "active" : "")"
                    @onclick='() => { NavTo("Snoozed"); CloseEmail(); }'>
                    <span class="material-icons">schedule</span>
                    <span class="nav-label">Snoozed</span>
                </li>
                <li class="gmail-nav-item @(_activeFolder == "Sent" && _openEmail == null ? "active" : "")"
                    @onclick='() => { NavTo("Sent"); CloseEmail(); }'>
                    <span class="material-icons">send</span>
                    <span class="nav-label">Sent</span>
                </li>
                <li class="gmail-nav-item @(_activeFolder == "Drafts" && _openEmail == null ? "active" : "")"
                    @onclick='() => { NavTo("Drafts"); CloseEmail(); }'>
                    <span class="material-icons">insert_drive_file</span>
                    <span class="nav-label">Drafts</span>
                    @if (_draftsCount > 0) { <span class="nav-badge">@_draftsCount</span> }
                </li>
                @if (_showMoreNav)
                {
                    <li class="gmail-nav-item @(_activeFolder == "AllMail" ? "active" : "")"
                        @onclick='() => { NavTo("AllMail"); CloseEmail(); }'>
                        <span class="material-icons">all_inbox</span>
                        <span class="nav-label">All Mail</span>
                    </li>
                    <li class="gmail-nav-item @(_activeFolder == "Spam" ? "active" : "")"
                        @onclick='() => { NavTo("Spam"); CloseEmail(); }'>
                        <span class="material-icons">report</span>
                        <span class="nav-label">Spam</span>
                    </li>
                    <li class="gmail-nav-item @(_activeFolder == "Trash" ? "active" : "")"
                        @onclick='() => { NavTo("Trash"); CloseEmail(); }'>
                        <span class="material-icons">delete</span>
                        <span class="nav-label">Trash</span>
                    </li>
                }
                <li class="gmail-nav-item gmail-nav-more" @onclick="ToggleMoreNav">
                    <span class="material-icons">@(_showMoreNav ? "expand_less" : "expand_more")</span>
                    <span class="nav-label">@(_showMoreNav ? "Less" : "More")</span>
                </li>
            </ul>
            <div class="gmail-sidebar-section">
                <div class="gmail-sidebar-section-label">Labels</div>
                <ul class="gmail-nav-list">
                    <li class="gmail-nav-item">
                        <span class="nav-label-dot" style="background:#d50000"></span>
                        <span class="nav-label">Important</span>
                    </li>
                    <li class="gmail-nav-item">
                        <span class="nav-label-dot" style="background:#0b8043"></span>
                        <span class="nav-label">Work</span>
                    </li>
                    <li class="gmail-nav-item">
                        <span class="nav-label-dot" style="background:#1a73e8"></span>
                        <span class="nav-label">Personal</span>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- ===== EMAIL LIST VIEW ===== -->
        @if (_openEmail == null)
        {
            <main class="gmail-email-list">
                @if (_activeFolder == "Inbox")
                {
                    <div class="gmail-tabs" role="tablist">
                        <button class="gmail-tab @(_activeTab == "Primary" ? "active" : "")"
                                role="tab" @onclick='() => _activeTab = "Primary"'>
                            <span class="material-icons">inbox</span><span>Primary</span>
                        </button>
                        <button class="gmail-tab @(_activeTab == "Social" ? "active" : "")"
                                role="tab" @onclick='() => _activeTab = "Social"'>
                            <span class="material-icons">people</span><span>Social</span>
                        </button>
                        <button class="gmail-tab @(_activeTab == "Promotions" ? "active" : "")"
                                role="tab" @onclick='() => _activeTab = "Promotions"'>
                            <span class="material-icons">local_offer</span><span>Promotions</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="folder-header">
                        <span class="folder-title">@FolderDisplayName</span>
                    </div>
                }

                @foreach (var email in FilteredEmails)
                {
                    <div class="gmail-email-row @(email.Unread ? "unread" : "")"
                         @onclick="() => OpenEmail(email)">
                        <div class="row-check" @onclick:stopPropagation="true">
                            <input type="checkbox" class="email-checkbox" aria-label="Select email" />
                        </div>
                        <button class="row-star @(email.Starred ? "starred" : "")"
                                aria-label="@(email.Starred ? "Starred" : "Not starred")"
                                @onclick:stopPropagation="true"
                                @onclick="() => ToggleStar(email)">
                            <span class="material-icons">@(email.Starred ? "star" : "star_border")</span>
                        </button>
                        <div class="row-sender">@email.Sender</div>
                        <div class="row-subject">
                            <span class="subject-text">@email.Subject</span>
                            <span class="subject-snippet"> — @email.Snippet</span>
                        </div>
                        @if (email.HasAttachment)
                        {
                            <span class="row-attach material-icons" title="Has attachment">attach_file</span>
                        }
                        <div class="row-time">@email.Time</div>
                    </div>
                }

                @if (!FilteredEmails.Any())
                {
                    <div class="folder-empty">
                        <span class="material-icons">@FolderEmptyIcon</span>
                        <p>No conversations in @FolderDisplayName</p>
                    </div>
                }
            </main>
        }

        <!-- ===== EMAIL READING VIEW ===== -->
        @{ var mail = _openEmail; }
        @if (mail != null)
        {
            var mailList = FilteredEmails.ToList();
            var mailIdx  = mailList.IndexOf(mail);
            <main class="email-view">

                <!-- Reading toolbar -->
                <div class="ev-toolbar">
                    <button class="ev-icon-btn" aria-label="Back to inbox" @onclick="CloseEmail">
                        <span class="material-icons">arrow_back</span>
                    </button>
                    <div class="ev-toolbar-actions">
                        <button class="ev-icon-btn ev-hide-sm" title="Archive" @onclick="CloseEmail">
                            <span class="material-icons">archive</span>
                        </button>
                        <button class="ev-icon-btn ev-hide-sm" title="Report spam">
                            <span class="material-icons">report_gmailerrorred</span>
                        </button>
                        <button class="ev-icon-btn ev-hide-sm" title="Delete">
                            <span class="material-icons">delete</span>
                        </button>
                        <div class="ev-sep ev-hide-sm"></div>
                        <button class="ev-icon-btn ev-hide-md" title="Mark as unread">
                            <span class="material-icons">mark_email_unread</span>
                        </button>
                        <button class="ev-icon-btn ev-hide-md" title="Snooze">
                            <span class="material-icons">schedule</span>
                        </button>
                        <button class="ev-icon-btn ev-hide-md" title="Add to tasks">
                            <span class="material-icons">task_alt</span>
                        </button>
                        <div class="ev-sep ev-hide-md"></div>
                        <button class="ev-icon-btn ev-hide-md" title="Move to">
                            <span class="material-icons">drive_file_move</span>
                        </button>
                        <button class="ev-icon-btn ev-hide-md" title="Labels">
                            <span class="material-icons">label</span>
                        </button>
                        <button class="ev-icon-btn" title="More options">
                            <span class="material-icons">more_vert</span>
                        </button>
                    </div>
                    <div class="ev-toolbar-nav">
                        <span class="ev-nav-count ev-hide-sm">
                            @(mailIdx + 1) of @mailList.Count
                        </span>
                        <button class="ev-icon-btn" title="Newer" @onclick="NavPrevEmail"
                                disabled="@(mailIdx <= 0)">
                            <span class="material-icons">chevron_left</span>
                        </button>
                        <button class="ev-icon-btn" title="Older" @onclick="NavNextEmail"
                                disabled="@(mailIdx >= mailList.Count - 1)">
                            <span class="material-icons">chevron_right</span>
                        </button>
                    </div>
                </div>

                <!-- Email content -->
                <div class="ev-content">

                    <h1 class="ev-subject">@mail.Subject</h1>

                    <div class="ev-labels">
                        <span class="ev-label ev-label-inbox">Inbox</span>
                        @if (mail.Starred)
                        {
                            <span class="ev-label ev-label-starred">Starred</span>
                        }
                    </div>

                    <!-- Message card -->
                    <div class="ev-message-card">
                        <div class="ev-message-header" @onclick="ToggleHeaderExpand">
                            <div class="ev-sender-avatar" style="background:@SenderColor(mail.Sender)">
                                @(string.IsNullOrWhiteSpace(mail.Sender) ? "?" : mail.Sender.Trim()[0].ToString().ToUpper())
                            </div>

                            <div class="ev-sender-info">
                                <div class="ev-sender-row">
                                    <span class="ev-sender-name">@mail.Sender</span>
                                    @if (!string.IsNullOrEmpty(mail.SenderEmail))
                                    {
                                        <span class="ev-sender-email">&lt;@mail.SenderEmail&gt;</span>
                                    }
                                </div>
                                <div class="ev-to-row">
                                    <span>to <strong>me</strong></span>
                                    <span class="material-icons ev-chevron">
                                        @(_headerExpanded ? "expand_less" : "expand_more")
                                    </span>
                                </div>
                                @if (_headerExpanded)
                                {
                                    <div class="ev-header-detail">
                                        <div class="ev-detail-row">
                                            <span class="ev-detail-label">from:</span>
                                            <span>@mail.Sender @(!string.IsNullOrEmpty(mail.SenderEmail) ? $"<{mail.SenderEmail}>" : "")</span>
                                        </div>
                                        <div class="ev-detail-row">
                                            <span class="ev-detail-label">to:</span>
                                            <span>@_userEmail</span>
                                        </div>
                                        <div class="ev-detail-row">
                                            <span class="ev-detail-label">date:</span>
                                            <span>@mail.FullDate</span>
                                        </div>
                                        <div class="ev-detail-row">
                                            <span class="ev-detail-label">subject:</span>
                                            <span>@mail.Subject</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="ev-message-meta">
                                <span class="ev-msg-date">@mail.FullDate</span>
                                <div class="ev-msg-actions">
                                    <button class="ev-icon-btn" title="Star"
                                            @onclick:stopPropagation="true"
                                            @onclick="() => ToggleStar(mail)">
                                        <span class="material-icons @(mail.Starred ? "ev-starred" : "")">
                                            @(mail.Starred ? "star" : "star_border")
                                        </span>
                                    </button>
                                    <button class="ev-icon-btn ev-hide-sm" title="Reply">
                                        <span class="material-icons">reply</span>
                                    </button>
                                    <button class="ev-icon-btn" title="More">
                                        <span class="material-icons">more_vert</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="ev-message-body">
                            @((MarkupString)mail.Body)
                        </div>

                        @if (mail.HasAttachment)
                        {
                            <div class="ev-attachments">
                                <div class="ev-attachment">
                                    <span class="material-icons ev-attach-icon">picture_as_pdf</span>
                                    <div class="ev-attach-info">
                                        <div class="ev-attach-name">document.pdf</div>
                                        <div class="ev-attach-size">124 KB · PDF</div>
                                    </div>
                                    <div class="ev-attach-actions">
                                        <button class="ev-icon-btn" title="Download">
                                            <span class="material-icons">download</span>
                                        </button>
                                        <button class="ev-icon-btn" title="Save to Drive">
                                            <span class="material-icons">add_to_drive</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="ev-reply-area">
                        <button class="ev-reply-btn">
                            <span class="material-icons">reply</span>
                            Reply
                        </button>
                        <button class="ev-reply-btn">
                            <span class="material-icons">forward</span>
                            Forward
                        </button>
                    </div>

                </div>
            </main>
        }

    </div>
</div>

@code {
    private class EmailItem
    {
        public string Sender       { get; set; } = "";
        public string SenderEmail  { get; set; } = "";
        public string Subject      { get; set; } = "";
        public string Snippet      { get; set; } = "";
        public string Body         { get; set; } = "";
        public string Time         { get; set; } = "";
        public string FullDate     { get; set; } = "";
        public bool   Unread       { get; set; }
        public bool   Starred      { get; set; }
        public string Tab          { get; set; } = "Primary";
        public string Folder       { get; set; } = "Inbox";
        public bool   HasAttachment{ get; set; }
    }

    private string _activeFolder    = "Inbox";
    private string _activeTab       = "Primary";
    private bool   _sidebarOpen;
    private bool   _showMoreNav;
    private bool   _showAccountMenu;
    private bool   _headerExpanded;
    private string _searchQuery     = "";
    private string _userEmail       = "user@gmail.com";
    private EmailItem? _openEmail;

    private string _userInitial => string.IsNullOrEmpty(_userEmail) ? "G" : _userEmail[0].ToString().ToUpper();

    private static string SenderColor(string s) => s switch
    {
        var n when n.StartsWith("Google") || n.StartsWith("accounts") => "#1a73e8",
        var n when n.StartsWith("YouTube")    => "#ea4335",
        var n when n.StartsWith("LinkedIn")   => "#0077b5",
        var n when n.StartsWith("Draft")      => "#80868b",
        var n when n.StartsWith("me")         => "#1a73e8",
        _ => "#9c27b0"
    };

    private void NavTo(string folder) { _activeFolder = folder; _activeTab = "Primary"; _sidebarOpen = false; }
    private void ToggleSidebar()  => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar()   => _sidebarOpen = false;
    private void ToggleMoreNav()  => _showMoreNav = !_showMoreNav;
    private void ToggleStar(EmailItem e) => e.Starred = !e.Starred;
    private void ToggleAccountMenu() => _showAccountMenu = !_showAccountMenu;
    private void ToggleHeaderExpand() => _headerExpanded = !_headerExpanded;
    private void SignOut() => Nav.NavigateTo("/", forceLoad: true);

    private void OpenEmail(EmailItem email)
    {
        _openEmail = email;
        _headerExpanded = false;
        _sidebarOpen = false;
        if (email.Unread) email.Unread = false;
    }

    private void CloseEmail()
    {
        _openEmail = null;
        _headerExpanded = false;
    }

    private void NavPrevEmail()
    {
        var list = FilteredEmails.ToList();
        var idx  = list.IndexOf(_openEmail!);
        if (idx > 0) OpenEmail(list[idx - 1]);
    }

    private void NavNextEmail()
    {
        var list = FilteredEmails.ToList();
        var idx  = list.IndexOf(_openEmail!);
        if (idx < list.Count - 1) OpenEmail(list[idx + 1]);
    }

    private IEnumerable<EmailItem> FilteredEmails
    {
        get
        {
            var emails = _activeFolder == "Inbox"
                ? _allEmails.Where(e => e.Folder == "Inbox" && e.Tab == _activeTab)
                : _activeFolder == "AllMail"
                    ? _allEmails
                    : _allEmails.Where(e => e.Folder == _activeFolder);

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var q = _searchQuery.ToLower();
                emails = emails.Where(e =>
                    e.Sender.ToLower().Contains(q) ||
                    e.Subject.ToLower().Contains(q) ||
                    e.Snippet.ToLower().Contains(q));
            }
            return emails;
        }
    }

    private int _inboxUnreadCount => _allEmails.Count(e => e.Folder == "Inbox" && e.Unread);
    private int _draftsCount      => _allEmails.Count(e => e.Folder == "Drafts");

    private string FolderDisplayName => _activeFolder switch { "AllMail" => "All Mail", _ => _activeFolder };

    private string FolderEmptyIcon => _activeFolder switch
    {
        "Starred"  => "star_border",
        "Snoozed"  => "schedule",
        "Sent"     => "send",
        "Drafts"   => "insert_drive_file",
        "Spam"     => "report",
        "Trash"    => "delete",
        "AllMail"  => "all_inbox",
        _          => "inbox"
    };

    private readonly List<EmailItem> _allEmails =
    [
        new()
        {
            Sender="Google", SenderEmail="no-reply@accounts.google.com",
            Subject="Security alert",
            Snippet="A new sign-in on Windows. If this was you…",
            Time="Just now", FullDate="Mon, May 18, 2026, 11:42 AM",
            Unread=true, Folder="Inbox", Tab="Primary",
            Body="""
                <p>Hi,</p>
                <p>Your Google Account <strong>user@gmail.com</strong> was just signed in to from a new Windows device.</p>
                <table style="margin:16px 0;border-collapse:collapse;">
                  <tr><td style="padding:4px 16px 4px 0;color:#5f6368;font-size:13px;">Device</td><td style="font-size:13px;">Windows · Chrome</td></tr>
                  <tr><td style="padding:4px 16px 4px 0;color:#5f6368;font-size:13px;">Location</td><td style="font-size:13px;">United States (approximate)</td></tr>
                  <tr><td style="padding:4px 16px 4px 0;color:#5f6368;font-size:13px;">Time</td><td style="font-size:13px;">Monday, May 18, 2026 at 11:42 AM UTC</td></tr>
                </table>
                <p>If this was you, you don't need to do anything. If you don't recognize this sign-in, your account may be compromised. <a href="#" style="color:#1a73e8;">Secure your account now.</a></p>
                <br><p style="color:#5f6368;font-size:13px;">— The Google Accounts Team</p>
                <p style="font-size:11px;color:#80868b;margin-top:24px;">Google LLC, 1600 Amphitheatre Pkwy, Mountain View, CA 94043</p>
            """
        },
        new()
        {
            Sender="Google Team", SenderEmail="googleteam@google.com",
            Subject="Welcome to Google",
            Snippet="Your new account is ready. Get started with Google…",
            Time="2:14 PM", FullDate="Mon, May 18, 2026, 2:14 PM",
            Unread=true, Folder="Inbox", Tab="Primary", HasAttachment=true,
            Body="""
                <p>Hi there,</p>
                <p>Welcome to Google! Your account is all set and ready to use.</p>
                <p>Here's what you can do with your Google Account:</p>
                <ul style="margin:12px 0;padding-left:20px;line-height:2;">
                  <li><strong>Gmail</strong> — Send, receive and organize your email</li>
                  <li><strong>Google Drive</strong> — Store 15 GB of files for free</li>
                  <li><strong>Google Photos</strong> — Back up and share your memories</li>
                  <li><strong>YouTube</strong> — Watch and create videos</li>
                  <li><strong>Google Maps</strong> — Explore the world</li>
                </ul>
                <p>Visit <a href="#" style="color:#1a73e8;">myaccount.google.com</a> to manage your account settings and personalize your experience.</p>
                <br><p>Cheers,<br><strong>The Google Team</strong></p>
            """
        },
        new()
        {
            Sender="Google Play", SenderEmail="googleplay-noreply@google.com",
            Subject="Your receipt from Google Play",
            Snippet="Order confirmation · Google One 100 GB…",
            Time="10:03 AM", FullDate="Mon, May 18, 2026, 10:03 AM",
            Unread=true, Folder="Inbox", Tab="Primary", HasAttachment=true,
            Body="""
                <p>Thanks for your purchase!</p>
