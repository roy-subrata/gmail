@page "/email-dashboard"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject GmailApp.Services.EmailService EmailService
@inject GmailApp.Services.EmailTemplateService TemplateService
@inject Microsoft.Extensions.Options.IOptions<GmailApp.Models.SmtpSettings> SmtpOptions

<PageTitle>Email Dashboard</PageTitle>

<div class="ed-wrapper">

    <div class="ed-header">
        <a href="/dashboard" class="ed-back-btn" aria-label="Back to Dashboard" title="Back to Dashboard">
            <span class="material-icons">arrow_back</span>
        </a>
        <span class="material-icons">send</span>
        <h1>Email Dashboard</h1>
        <a href="/do-logout" class="ed-logout-btn" title="Sign out" aria-label="Sign out">
            <span class="material-icons">logout</span>
        </a>
    </div>

    <div class="ed-layout">

        <!-- ── LEFT: form ─────────────────────────────── -->
        <div class="ed-form-col">
            <div class="ed-card">

                <div class="ed-field">
                    <label class="ed-label">From</label>
                    <input type="email" @bind="fromEmail"
                           placeholder="sender@yourdomain.com"
                           class="@Cls(fromError)" />
                    @if (fromError) { <span class="ed-error-msg">Enter a valid email address</span> }
                    @if (!string.IsNullOrWhiteSpace(SmtpOptions.Value.SenderName))
                    {
                        <span class="ed-hint">Sent as: @SmtpOptions.Value.SenderName &lt;@SmtpOptions.Value.SenderEmail&gt;</span>
                    }
                </div>

                <div class="ed-field">
                    <label class="ed-label">To</label>
                    <input type="email" @bind="toEmail" @bind:after="OnToChanged"
                           placeholder="recipient@example.com"
                           class="@Cls(toError)" />
                    @if (toError) { <span class="ed-error-msg">Enter a valid email address</span> }
                </div>

                <div class="ed-field">
                    <label class="ed-label">Subject</label>
                    <input type="text" @bind="subject"
                           placeholder="Email subject..."
                           class="@Cls(subjectError)" />
                    @if (subjectError) { <span class="ed-error-msg">Subject is required</span> }
                </div>

                <div class="ed-field">
                    <label class="ed-label">Template</label>
                    <select class="ed-select" @onchange="OnTemplateChanged">
                        <option value="">— select a template —</option>
                        @foreach (var t in templates)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>

                @if (selectedTemplate is not null)
                {
                    <div class="ed-template-fields">
                        @foreach (var field in selectedTemplate.Fields)
                        {
                            <div class="ed-field">
                                <label class="ed-label">@field.Label</label>
                                <input type="@field.Type"
                                       value="@FieldVal(field.Key)"
                                       @oninput="e => OnFieldInput(field.Key, e.Value?.ToString() ?? string.Empty)"
                                       placeholder="@field.Placeholder"
                                       class="ed-input" />
                            </div>
                        }
                    </div>
                }

                <!-- Actions -->
                <div class="ed-actions">
                    <button class="ed-btn-primary" @onclick="SendEmail" disabled="@isSending">
                        @if (isSending)
                        {
                            <span class="material-icons ed-icon-spin">autorenew</span>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span class="material-icons">send</span>
                            <span>Send</span>
                        }
                    </button>
                    <button class="ed-btn-secondary" @onclick="ClearForm" disabled="@isSending">
                        <span class="material-icons">delete_sweep</span>
                        <span>Clear</span>
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="@(isSuccess ? "ed-status ed-status-ok" : "ed-status ed-status-err")">
                        <span class="material-icons">@(isSuccess ? "check_circle" : "error_outline")</span>
                        <span>@statusMessage</span>
                    </div>
                }

            </div>
        </div>

        <!-- ── RIGHT: preview ─────────────────────────── -->
        <div class="ed-preview-col">
            <div class="ed-preview-bar">
                <span class="material-icons">preview</span>
                <span>Preview</span>
            </div>
            <div class="ed-preview-body">
                @if (string.IsNullOrEmpty(previewHtml))
                {
                    <div class="ed-preview-empty">
                        <span class="material-icons">mail_outline</span>
                        <p>Choose a template to see a live preview</p>
                    </div>
                }
                else
                {
                    <iframe id="preview-iframe"
                            class="ed-preview-iframe"
                            sandbox="allow-same-origin"
                            title="Email preview">
                    </iframe>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private string fromEmail    = string.Empty;
    private string toEmail      = string.Empty;
    private string subject      = string.Empty;
    private string statusMessage = string.Empty;
    private string previewHtml  = string.Empty;

    private bool fromError, toError, subjectError, isSending, isSuccess;

    private List<GmailApp.Models.EmailTemplate> templates = new();
    private GmailApp.Models.EmailTemplate? selectedTemplate;
    private Dictionary<string, string> fields = new();

    protected override void OnInitialized()
    {
        templates = TemplateService.GetTemplates();
        fromEmail = SmtpOptions.Value.SenderEmail;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(previewHtml))
            await JS.InvokeVoidAsync("setIframeSrcdoc", "preview-iframe", previewHtml);
    }

    // ── template events ────────────────────────────────────────────────────────

    private void OnTemplateChanged(ChangeEventArgs e)
    {
        var id = e.Value?.ToString() ?? string.Empty;
        selectedTemplate = templates.FirstOrDefault(t => t.Id == id);
        fields = new();

        if (selectedTemplate is null) { previewHtml = string.Empty; return; }

        foreach (var f in selectedTemplate.Fields)
            fields[f.Key] = f.DefaultValue;

        if (!string.IsNullOrWhiteSpace(toEmail) && fields.ContainsKey("recipientEmail"))
            fields["recipientEmail"] = toEmail;

        subject = TemplateService.BuildSubject(selectedTemplate.Id, fields);
        RefreshPreview();
    }

    private void OnFieldInput(string key, string value)
    {
        fields[key] = value;

        if (key == "recipientEmail" && IsValidEmail(value))
            toEmail = value;

        if (selectedTemplate is not null)
            subject = TemplateService.BuildSubject(selectedTemplate.Id, fields);

        RefreshPreview();
    }

    private Task OnToChanged()
    {
        if (selectedTemplate is not null && fields.ContainsKey("recipientEmail"))
        {
            fields["recipientEmail"] = toEmail;
            RefreshPreview();
        }
        return Task.CompletedTask;
    }

    private void RefreshPreview()
    {
        if (selectedTemplate is not null)
            previewHtml = selectedTemplate.BuildHtml(fields);
    }

    private string FieldVal(string key) =>
        fields.TryGetValue(key, out var v) ? v : string.Empty;

    // ── send / clear ───────────────────────────────────────────────────────────

    private async Task SendEmail()
    {
        fromError    = !IsValidEmail(fromEmail);
        toError      = !IsValidEmail(toEmail);
        subjectError = string.IsNullOrWhiteSpace(subject);
        statusMessage = string.Empty;

        if (fromError || toError || subjectError) return;

        if (selectedTemplate is null)
        {
            statusMessage = "Please select a template.";
            isSuccess = false;
            return;
        }

        var htmlBody = selectedTemplate.BuildHtml(fields);

        isSending = true;
        StateHasChanged();

        var (success, error) = await EmailService.SendAsync(fromEmail, toEmail, subject, htmlBody);

        isSending = false;
        isSuccess = success;
        statusMessage = success ? "Email sent successfully!" : $"Failed to send: {error}";
    }

    private void ClearForm()
    {
        fromEmail = toEmail = subject = statusMessage = previewHtml = string.Empty;
        fromError = toError = subjectError = false;
        selectedTemplate = null;
        fields = new();
    }

    // ── helpers ────────────────────────────────────────────────────────────────

    private static string Cls(bool err) => err ? "ed-input ed-input-error" : "ed-input";

    private static bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        try { return new System.Net.Mail.MailAddress(email.Trim()).Address == email.Trim(); }
        catch { return false; }
    }
}
